# Copy this file to terraform.tfvars and adjust values for your environment:
#   cp infra/terraform/terraform.tfvars.example infra/terraform/terraform.tfvars

aws_region   = "us-east-1"
project_name = "fleet-strategy-engine"
environment  = "dev"

dashboard_cpu          = 512
dashboard_memory       = 1024
dashboard_min_capacity = 1
dashboard_max_capacity = 2

ecr_max_images                     = 2
raw_upload_expiration_days         = 7
processed_run_expiration_days      = 30
noncurrent_version_expiration_days = 7

# Leave empty to deploy without the assistant. If enabled, create this
# SecureString in SSM Parameter Store before deploying.
google_api_key_parameter_name = ""
# google_api_key_parameter_name = "/fleet-strategy-engine/dev/google-api-key"
gemini_model = "gemini-3.1-flash-lite"

# Image URIs are intentionally omitted. scripts/deploy_aws.sh builds the
# images, resolves their immutable ECR digests, and passes them to Terraform.
